# News Aggregator Environment Configuration
# Copy this file to .env and fill in your values

# News API Key (optional - leave empty to use RSS feeds only)
# NEWS_API_KEY=your_api_key_here

# Redis cache (optional - for production)
# REDIS_URL=redis://localhost:6379

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Maximum number of articles to fetch per request
MAX_ARTICLES=20

# Default time range for news (1h, 6h, 24h, 7d)
DEFAULT_TIME_RANGE=24h

# Rate limiting (requests per minute per source)
RATE_LIMIT=60

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Enable WebSocket streaming (true/false)
WEBSOCKET_ENABLED=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Trust proxy headers (true/false)
TRUST_PROXY=false
