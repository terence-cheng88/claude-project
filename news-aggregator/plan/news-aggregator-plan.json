  "architecture": {
    "diagram": "FastAPI backend with 6 agents: Feeder, Processor, Sentiment, Summarizer, Publisher, and Coordinator swarm manager",
    "backend": "Python + FastAPI (async)",
    "agents_framework": "Ruflo multi-agent framework",
    "news_sources": "RSS + JSON APIs (NewsAPI, GNews, RSS feeds)",
    "summary_engine": "Text summarizer or HuggingFace models",
    "sentiment_analysis": "TextBlob or transformers",
    "frontend": "Simple HTML + vanilla JS (no framework overhead)"
  },
  "agent_roles": {
    "coordinator": {
      "purpose": "Orchestrates the multi-agent workflow",
      "tasks": [
        "Receives news request (topic, time range, sources)",
        "Spawns appropriate feeder agents",
        "Distributes news to processor agents",
        "Aggregates results and routes to UI"
      ]
    },
    "feeder": {
      "purpose": "Fetch news from multiple sources",
      "tasks": [
        "Scrape/API calls to news sources (RSS, JSON APIs)",
        "Handle rate limiting and retries",
        "Normalize article metadata"
      ],
      "instances": "One per news source (TechCrunch, Reuters, Bloomberg, etc.)"
    },
    "processor": {
      "purpose": "Process raw news content",
      "tasks": [
        "Extract key entities (people, companies, topics)",
        "Classify topic/sector",
        "Detect spam/fake news signals"
      ]
    },
    "sentiment": {
      "purpose": "Analyze news sentiment",
      "tasks": [
        "Run sentiment analysis on articles",
        "Aggregate sentiment per topic",
        "Detect market-moving news"
      ]
    },
    "summarizer": {
      "purpose": "Generate concise summaries",
      "tasks": [
        "Create TL;DR for each article",
        "Generate topic-specific summaries",
        "Deduplicate overlapping content"
      ]
    },
    "publisher": {
      "purpose": "Push results to UI",
      "tasks": [
        "Format JSON response",
        "Stream to WebSocket (real-time)",
        "Cache results"
      ]
    }
  },
